{
  "entities": {
    "hero": {
      "title": "Hero Slide",
      "description": "Slideshow images and tagline for the hero section.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string", "description": "URL of the hero image." },
        "tagline": { "type": "string", "description": "Tagline text overlay." },
        "order": { "type": "number", "description": "Display order." }
      },
      "required": ["imageUrl", "tagline", "order"]
    },
    "services": {
      "title": "Service",
      "description": "Services offered by HS Planning Ltd.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Service title." },
        "description": { "type": "string", "description": "Brief description." },
        "order": { "type": "number", "description": "Display order." }
      },
      "required": ["title", "description", "order"]
    },
    "projects": {
      "title": "Project",
      "description": "Portfolio projects categorized by status.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title." },
        "imageUrl": { "type": "string", "description": "Project image URL." },
        "location": { "type": "string", "description": "Project location." },
        "date": { "type": "string", "description": "Project date." },
        "description": { "type": "string", "description": "Project details." },
        "category": { "type": "string", "enum": ["success", "progressing", "upcoming"], "description": "Project status category." }
      },
      "required": ["title", "imageUrl", "location", "date", "description", "category"]
    },
    "reviews": {
      "title": "Review",
      "description": "Client testimonials.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Client name." },
        "review": { "type": "string", "description": "Review text." },
        "rating": { "type": "number", "description": "Star rating (1-5)." }
      },
      "required": ["name", "review", "rating"]
    },
    "contactInfo": {
      "title": "Contact Info",
      "description": "Company contact details.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Contact email." },
        "whatsapp": { "type": "string", "description": "WhatsApp number." },
        "name": { "type": "string", "description": "Consultant name." }
      },
      "required": ["email", "whatsapp", "name"]
    }
  },
  "firestore": {
    "/hero/{id}": { "schema": "hero", "description": "Hero slideshow data." },
    "/services/{id}": { "schema": "services", "description": "List of services." },
    "/projects/{id}": { "schema": "projects", "description": "Portfolio projects." },
    "/reviews/{id}": { "schema": "reviews", "description": "Client reviews." },
    "/contactInfo/{id}": { "schema": "contactInfo", "description": "Contact details." }
  }
}
